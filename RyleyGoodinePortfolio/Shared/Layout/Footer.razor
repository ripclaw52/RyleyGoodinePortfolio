@using RyleyGoodinePortfolio.Component.Icons
<!--
    Footer component that will encompass every page
    - social media links
    - contact information
-->
<footer class="app-footer">
    <div class="footer-container">

        <!-- Branding -->
        <div class="footer-section">
            <h3>RG</h3>
            [blurb about my work]
        </div>

        <!-- Navigation 
        <div class="footer-section">
            <h4>Sitemap</h4>
            <ul>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/faq">FAQ</a></li>
            </ul>
        </div>
        -->

        <!-- Contact -->
        <div class="footer-section">
            <h4>Contact</h4>
            <p>Email: ryleygoodine96@gmail.com</p>
            <p>Phone: &#x1f1e8;&#x1f1e6; +1 (587) 987-0072</p>
        </div>

         <!-- Social -->
        <div class="footer-section">
            <h4>Follow Me</h4>

            <!-- Text Sites -->
            <div class="social-icons">
                <!-- Facebook -->
                <SocialIcon Platform="SocialPlatform.Facebook" />

                <!-- Twitter/X -->
                <SocialIcon Platform="SocialPlatform.Twitter" />

                <!-- LinkedIn -->
                <SocialIcon Platform="SocialPlatform.LinkedIn" />
            </div>

            <!-- Video Sites -->
            <div class="social-icons">
                <!-- Youtube -->
                <SocialIcon Platform="SocialPlatform.YouTube" />

                <!-- Instagram -->
                <SocialIcon Platform="SocialPlatform.Instagram" />

                <!-- Dailymotion -->
                <SocialIcon Platform="SocialPlatform.DailyMotion" />
            </div>

            <!-- Other Sites -->
            <div class="social-icons">
                <!-- GitHub -->
                <SocialIcon Platform="SocialPlatform.GitHub" />

                <!-- Reddit -->
                <SocialIcon Platform="SocialPlatform.Reddit" />

                <!-- Twitch -->
                <SocialIcon Platform="SocialPlatform.Twitch" />
            </div>
        </div>

    </div>
</footer>

<style>
    .app-footer {
        background-color: #2f2937;
        color: #e5e7eb;
        padding: 40px 20px;
        margin-top: 40px;
    }

    .footer-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: auto;
    }

    .footer-section h3,
    .footer-section h4 {
        margin-bottom: 10px;
        color: #ffffff;
    }

    .footer-section p {
        margin: 5px 0;
        color: #9ca3af;
    }

    .footer-section ul {
        list-style: none;
        padding: 0;
    }

    .footer-section li {
        margin-bottom: 8px;
    }

    .footer-section a {
        color: #9ca3af;
        text-decoration: none;
    }

        .footer-section a:hover {
            color: #ffffff;
        }
    
    .social-icons {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }

        .social-icons a {
            display: inline-flex;
            width: 32px;
            height: 32px;
            align-items: center;
            justify-content: center;
            background-color: #374151;
            border-radius: 50%;
            transition: background 0.2s ease;
        }

            .social-icons a:hover {
                background-color: #4b5563;
            }

        .social-icons svg {
            width: 18px;
            height: 18px;
            fill: #e5e7eb;
        }

</style>