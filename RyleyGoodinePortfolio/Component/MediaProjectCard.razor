@using RyleyGoodinePortfolio.Models

<article class="media-card">

    @if (Media is not null)
    {
        @if (Media.Type == MediaType.Image)
        {
            <img src="@Media.Url"
                 alt="@Media.Caption"
                 class="media-preview" />

            <div class="card-content">
                <h3> @Media.Caption </h3>
            </div>
        }

        @if (Media.Type == MediaType.Video)
        {
            <div class="video-thumbnail"
                 @onclick="OpenVideo">

                <img src="@GetThumbnailUrl()"
                     alt="@Media.Caption" />

                <div class="play-button">
                    ▶
                </div>

            </div>

            <div class="card-content">
                <h3> @Media.Caption </h3>
                <p>
                    Watch video 
                    <a href="@Media.Url" target="_blank">here</a>
                </p>
            </div>
        }
    }
</article>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseVideo">
        
        <div class="modal-content"
             @onclick:stopPropagation>

            <iframe src="@GetEmbedUrl()"
                    title="@Media.Caption"
                    allowfullscreen
                    allow="fullscreen; picture-in-picture; web-share">
            </iframe>

        </div>
        <button class="close-btn" @onclick="CloseVideo">✕</button>
    </div>
}

<!-- Modal styles and video thumbnail styles -->
<style>
    /* Modal styles */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.8);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-content {
        width: 50%;
        max-width: 900px;
        position: relative;
        padding-bottom: 56.25%;
    }

        .modal-content iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

    /* Video thumbnail styles */
    .video-thumbnail {
        position: relative;
        cursor: pointer;
    }

        .video-thumbnail img {
            width: 100%;
            display: block;
        }

    .play-button {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 3rem;
        color: white;
        background: rgba(0,0,0,0.5);
        border-radius: 50%;
        padding: 10px 18px;
    }

    /* Card styles */
    .media-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .media-preview {
        width: 100%;
        display: block;
    }

    .video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
    }

        .video-wrapper iframe {
            width: 100%;
            height: 100%;
            position: absolute;
            left: 0px;
            top: 0px;
            overflow: hidden;
            border: none;
        }

    .card-content {
        padding: 1.25rem;
    }

    .software-tag {
        display: inline-block;
        margin-top: .5rem;
        background: #e5e7eb;
        padding: .35rem .75rem;
        border-radius: 999px;
    }

    .media-count {
        margin-top: 1rem;
        font-size: .9rem;
        color: #6b7280;
    }
</style>


@code {

    bool showModal = false;
    void OpenVideo() => showModal = true;
    void CloseVideo() => showModal = false;


    [Parameter]
    public ProjectMedia Media { get; set; } = new();

    // Open the video in a new tab when the thumbnail is clicked
    private string GetThumbnailUrl()
    {
        // Extract video ID from URL
        var id = Media.Url.Split("video=").Last();

        return $"https://www.dailymotion.com/thumbnail/video/{id}";
    }

    // Get the embed URL for the video, ensuring it is safe for embedding
    private string GetEmbedUrl()
    {
        var id = Media.Url.Split("video=").Last();
        return $"https://geo.dailymotion.com/player.html?video={id}&autoplay=0&controls=1";
    }
}