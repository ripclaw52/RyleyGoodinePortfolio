@using RyleyGoodinePortfolio.Models

<article class="media-card">

    @if (Media is not null)
    {
        @if (Media.Type == MediaType.Image)
        {
            <img src="@Media.Url"
                 alt="@Media.Caption"
                 class="media-preview" />
        }

        @if (Media.Type == MediaType.Video)
        {
            <div class="video-wrapper">
                <iframe src="@Media.Url"
                        allowfullscreentitle="@Media.Caption"
                        allow="web-share"
                        >
                </iframe>
            </div>
        }
    }

    <div class="card-content">

        <h3> @Media.Caption </h3>

    </div>

</article>

<style>
    .media-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .media-preview {
        width: 100%;
        display: block;
    }

    .video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
    }

        .video-wrapper iframe {
            width: 100%;
            height: 100%;
            position: absolute;
            left: 0px;
            top: 0px;
            overflow: hidden;
            border: none;
        }

    .card-content {
        padding: 1.25rem;
    }

    .software-tag {
        display: inline-block;
        margin-top: .5rem;
        background: #e5e7eb;
        padding: .35rem .75rem;
        border-radius: 999px;
    }

    .media-count {
        margin-top: 1rem;
        font-size: .9rem;
        color: #6b7280;
    }
</style>


@code {

    [Parameter]
    public ProjectMedia Media { get; set; } = new();

}