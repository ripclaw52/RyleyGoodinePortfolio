@using RyleyGoodinePortfolio.Component
@using RyleyGoodinePortfolio.Data
@using RyleyGoodinePortfolio.Models
@page "/projects"

<PageTitle>Projects</PageTitle>

<section class="projects-page">

    <header class="projects-header">
        <h1>Projects</h1>
        <p>
            A selection of software, game development,
            and design projects I've built.
        </p>
    </header>

    <section class="project-grid">

        @foreach (var project in projects)
        {
            <ProjectCard
                ThumbnailUrl="@project.ThumbnailUrl"
                Slug="@project.Slug"
                Title="@project.Title"
                Description="@project.Summary"
                Technologies="@project.Technologies"
            />
        }

    </section>

</section>

<style>
    .projects-page {
        max-width: 1200px;
        margin: auto;
        padding: 4rem 2rem;
    }

    .projects-header {
        text-align: center;
        margin-bottom: 3rem;
    }

        .projects-header h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .projects-header p {
            max-width: 700px;
            margin: auto;
            color: #6b7280;
        }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(320px,1fr));
        gap: 2rem;
    }
</style>

@code {

    private List<Project> projects = new();

    protected override void OnInitialized()
    {
        projects = ProjectRepository.GetAll();
    }

}